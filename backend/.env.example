# MongoDB Atlas connection
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=know_way

# Demo user id — only used when CLERK_JWT_ISSUER is unset (local dev without Clerk)
DEMO_USER_ID=user_01

# Clerk JWT issuer from Clerk Dashboard → API keys → Advanced → JWT issuer
# Example: https://your-app.clerk.accounts.dev
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

PORT=8000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
EXPOSE_OPENAPI=true

# Google Vertex AI / ADC Configuration
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model configurations (defaults to flash for standard, pro for heavy reasoning agents)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
